# Server port
PORT=3001

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# football-data.org API key (free at https://www.football-data.org/client/register)
# Used to auto-sync World Cup match schedule and results
FOOTBALL_API_KEY=your_key_here

# Admin key for manual match result updates
ADMIN_KEY=change_this_secret

# SQLite database path
DB_PATH=./data/worldcup.db
